
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ClinicCare - Online Booking</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="styles.css" />
    <style>
        .hero {
            background: linear-gradient(to right, #00b4d8, #0077b6);
            height: 60vh;
            padding: 2rem;
        }

        .card:hover {
            transform: scale(1.03);
            transition: transform 0.3s ease;
        }

        .card-title {
            color: #0077b6;
            font-weight: bold;
        }

        footer {
            font-size: 0.9rem;
        }

    </style>
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container-fluid">
            <a class="navbar-brand" href="#">ClinicCare</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link active" href="#">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Admin/Login">Admin</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Doctor/Dregistration">Doctor</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Patient/Pregistration">Patient</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Contact</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero text-center text-white d-flex align-items-center justify-content-center">
        <div>
            <h1>Book Appointments with Ease</h1>
            <p class="lead">Trusted care from certified professionals</p>
            <img src="~/Images/patientdoctor.jpg" class="img-fluid rounded shadow" alt="Doctor with patient" />
        </div>
    </section>

    <!-- Features -->
    <section class="container py-5">
        <div class="row text-center">
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">Admin Panel</h5>
                        <p class="card-text">Manage doctors, patients, and appointments efficiently.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">Doctor Portal</h5>
                        <p class="card-text">Access schedules, patient details, and consultation history.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <a href="/Patient/BookAppointment">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title">Patient Access</h5>
                            <p class="card-text">Book appointments and view your medical records.</p>
                        </div>
                    </div>
                </a>
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section class="bg-light py-4 text-center">
        <h2>Contact Us</h2>
        <p>Email: support@clinicare.com | Phone: +91 98765 43210</p>
        <p>Address: 123 Health Street, Pune, India</p>
    </section>

    <!-- Footer -->
    <footer class="bg-primary text-white text-center py-3">
        <p>&copy; 2025 ClinicCare. All rights reserved.</p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

