@model Clinic1.Models.BookAppointment
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Book Appointment</title>

    <!-- ✅ Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        /* Background setup */
        body {
            background-image: url('/Content/Images/clinic-bg.jpg'); /* adjust image path */
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            font-family: 'Segoe UI', sans-serif;
        }

        /* Overlay to darken background slightly */
        .overlay {
            background-color: rgba(0, 0, 0, 0.5);
            position: absolute;
            inset: 0;
            z-index: 0;
        }

        /* Main container */
        .form-container {
            position: relative;
            z-index: 1;
            background-color: rgba(255, 255, 255, 0.95);
            border-radius: 15px;
            padding: 40px;
            max-width: 600px;
            margin: 80px auto;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
        }

        h2 {
            text-align: center;
            color: #007bff;
            margin-bottom: 25px;
            font-weight: 600;
        }

        label {
            font-weight: 500;
            color: #333;
        }

        .btn-primary {
            width: 100%;
            border-radius: 25px;
            font-weight: 600;
            padding: 10px;
        }

        .form-control {
            border-radius: 8px;
            margin-bottom: 15px;
        }

        .footer-text {
            text-align: center;
            color: #555;
            margin-top: 15px;
            font-size: 14px;
        }

       (max-width: 576px) {
            .form-container {
                margin: 30px 15px;
                padding: 25px;
            }

            h2 {
                font-size: 22px;
            }
        }
    </style>
</head>

<body>
    <div class="overlay"></div>

    <div class="form-container">
        @using (Html.BeginForm("BookAppointment", "Patient", FormMethod.Post))
        {
            <h2>Book Your Appointment</h2>

            <div class="mb-3">
                @Html.LabelFor(model => model.DoctorID, "Select Doctor")
                @Html.DropDownListFor(model => model.DoctorID, Model.DoctorList, "Select Doctor", new { @class = "form-control" })
                @Html.ValidationMessageFor(model => model.DoctorID, "", new { @class = "text-danger" })
            </div>

            <div class="mb-3">
                @Html.LabelFor(model => model.Date, "Appointment Date")
                @Html.TextBoxFor(model => model.Date, new { @class = "form-control", type = "date" })
                @Html.ValidationMessageFor(model => model.Date, "", new { @class = "text-danger" })
            </div>

            <div class="mb-3">
                @Html.LabelFor(model => model.Time, "Appointment Time")
                @Html.TextBoxFor(model => model.Time, new { @class = "form-control", type = "time" })
                @Html.ValidationMessageFor(model => model.Time, "", new { @class = "text-danger" })
            </div>

            <div class="mb-3">
                @Html.LabelFor(model => model.Disease, "Describe Your Symptoms")
                @Html.TextBoxFor(model => model.Disease, new { @class = "form-control", placeholder = "Describe your symptoms or condition" })
                @Html.ValidationMessageFor(model => model.Disease, "", new { @class = "text-danger" })
            </div>

            @Html.HiddenFor(model => model.PatientID)
            @Html.HiddenFor(model => model.Status, new { Value = "Pending" })

            <button type="submit" class="btn btn-primary mt-3">Book Appointment</button>

            <div class="footer-text">
                <p>We care for your health. Get the right treatment on time ❤️</p>
            </div>
        }
    </div>

    <!-- ✅ Bootstrap JS (for form responsiveness) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

