@model Clinic1.Models.Dashboard

@{
    ViewBag.Title = "Patient Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success text-center">
        @TempData["SuccessMessage"]
    </div>
}

<!-- Bootstrap CDN -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    html, body {
        height: 100%;
        margin: 0;
        font-family: 'Segoe UI', sans-serif;
    }

    /* Transparent background image */
    .bg-image {
        background-image: url('/Content/Images/doctor-patient-bg.jpg'); /* Replace with your image path */
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        position: fixed;
        width: 100%;
        height: 100%;
        opacity: 0.3; /* Controls transparency */
        z-index: -1;
    }

    .dashboard-content {
        position: relative;
        z-index: 1;
        padding: 40px 20px;
    }

    .card {
        background-color: rgba(255, 255, 255, 0.95);
        border-radius: 10px;
        box-shadow: 0 0 10px rgba(0,0,0,0.2);
    }

    .health-tips {
        background-color: rgba(240, 255, 240, 0.95);
        border-radius: 10px;
        padding: 15px;
    }
</style>

<!-- Background Image -->
<div class="bg-image"></div>

<!-- Dashboard Content -->
<div class="container dashboard-content">
    <h2 class="text-center text-primary mb-4">Welcome, @Model.PatientName!</h2>

    <div class="row g-4">
        <!-- Book Appointment -->
        <div class="col-md-4">
            <div class="card p-3 text-center">
                <h5>Book Appointment</h5>
                <p>Schedule a visit with your preferred doctor.</p>
                <a href="@Url.Action("BookAppointment", "Patient")" class="btn btn-success">Book Now</a>
            </div>
        </div>

        <!-- View History -->
        <div class="col-md-4">
            <div class="card p-3 text-center">
                <h5>Appointment History</h5>
                <p>Check your past and upcoming appointments.</p>
                <a href="@Url.Action("Index", "Appointment")" class="btn btn-info">View History</a>
            </div>
        </div>

        <!-- Cancel Appointment -->
        <div class="col-md-4">
            <div class="card p-3 text-center">
                <h5>Cancel Appointment</h5>
                <p>Need to reschedule? Cancel your booking here.</p>
                <a href="@Url.Action("MyAppointments", "Appointment")" class="btn btn-danger">Cancel</a>
            </div>
        </div>
    </div>

    <a href="@Url.Action("EditProfile", "Patient")" class="btn btn-warning mt-3">Edit Profile</a>


    <!-- Health Tips Section -->
    <div class="mt-5 health-tips shadow">
        <h5 class="text-success">Health Tips</h5>
        <ul>

            <li>🥗 Eat fresh fruits and vegetables daily.</li>
            <li>🚶‍Walk at least 30 minutes a day.</li>
            <li>💧 Stay hydrated—drink 6–8 glasses of water.</li>
            <li>😴 Get 7–8 hours of sleep every night.</li>
            <li>🧘‍♀️ Practice deep breathing or mindfulness.</li>
        </ul>
    </div>
</div>

